############################################
# Barblink — Docker dev stack environment.
# Copy to .env (which is gitignored) before running `docker compose up`.
############################################

# --- Postgres ---
POSTGRES_USER=barblink
POSTGRES_PASSWORD=barblink_dev
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Redpanda (Kafka) ---
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=barblink
MINIO_ROOT_PASSWORD=barblink_dev_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Meilisearch ---
MEILI_MASTER_KEY=barblink_dev_meili
MEILI_PORT=7700

# --- Landing page (only used when running `--profile landing`) ---
LANDING_PORT=3100
API_URL=http://host.docker.internal:3008
