{
  "compilerOptions": {
    "module": "commonjs", "declaration": true, "removeComments": true,
    "emitDecoratorMetadata": true, "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true, "target": "ES2022",
    "sourceMap": true, "outDir": "./dist", "baseUrl": "./",
    "incremental": true, "skipLibCheck": true, "strict": true,
    "noEmit": false, "esModuleInterop": true, "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.ts"], "exclude": ["node_modules", "dist"]
}
