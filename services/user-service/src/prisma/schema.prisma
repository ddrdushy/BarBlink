generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            String   @id @db.Uuid
  username      String   @unique @db.VarChar(30)
  displayName   String?  @map("display_name") @db.VarChar(60)
  bio           String?
  avatarUrl     String?  @map("avatar_url")
  country       String   @default("MY") @db.VarChar(2)
  drinkPrefs    String[] @default([]) @map("drink_prefs")
  goingTonight  Boolean  @default(false) @map("going_tonight")
  goingVenueId  String?  @map("going_venue_id") @db.Uuid
  lastSeenVenue String?  @map("last_seen_venue") @db.Uuid
  showLastSeen  Boolean  @default(true) @map("show_last_seen")
  isHomeSafe    Boolean  @default(false) @map("is_home_safe")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  followers  Follow[] @relation("following")
  following  Follow[] @relation("follower")

  @@map("profiles")
}

enum FollowStatus {
  pending
  accepted
  rejected
}

model Follow {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String       @map("follower_id") @db.Uuid
  followingId String       @map("following_id") @db.Uuid
  status      FollowStatus @default(pending)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  follower  Profile @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following Profile @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}
