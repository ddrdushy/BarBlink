generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  suspended
  banned
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone         String     @unique @db.VarChar(20)
  email         String     @db.VarChar(255)
  phoneVerified Boolean    @default(false) @map("phone_verified")
  dateOfBirth   DateTime   @map("date_of_birth") @db.Date
  googleId      String?    @unique @map("google_id")
  appleId       String?    @unique @map("apple_id")
  status        UserStatus @default(active)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  refreshTokens RefreshToken[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String   @db.VarChar(20)
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AdminAccount {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(254)
  passwordHash String    @map("password_hash")
  name         String    @db.VarChar(100)
  totpSecret   String?   @map("totp_secret")
  totpEnabled  Boolean   @default(false) @map("totp_enabled")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("admin_accounts")
}

model PlatformSetting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String
  description String?
  category    String   @db.VarChar(50)
  isSecret    Boolean  @default(true) @map("is_secret")
  isActive    Boolean  @default(true) @map("is_active")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("platform_settings")
}

model SettingsAuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settingKey   String   @map("setting_key") @db.VarChar(100)
  action       String   @db.VarChar(20)
  adminId      String   @map("admin_id") @db.Uuid
  adminName    String?  @map("admin_name") @db.VarChar(100)
  oldValueHash String?  @map("old_value_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("settings_audit_log")
}

model VendorAccount {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique @db.VarChar(254)
  passwordHash    String    @map("password_hash")
  businessName    String    @map("business_name") @db.VarChar(100)
  contactName     String    @map("contact_name") @db.VarChar(100)
  phone           String    @db.VarChar(20)
  businessType    String    @map("business_type") @db.VarChar(50)
  businessAddress String?   @map("business_address")
  instagramUrl    String?   @map("instagram_url")
  websiteUrl      String?   @map("website_url")
  adminMessage    String?   @map("admin_message")
  venueId         String?   @map("venue_id") @db.Uuid
  status          String    @default("pending") @db.VarChar(20)
  rejectionReason String?   @map("rejection_reason")
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("vendor_accounts")
}

model DjAccount {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String    @unique @db.VarChar(254)
  passwordHash     String    @map("password_hash")
  stageName        String    @map("stage_name") @db.VarChar(100)
  djType           String    @map("dj_type") @db.VarChar(20)
  genres           String[]  @default([])
  bio              String?
  instagramUrl     String?   @map("instagram_url")
  phone            String?   @db.VarChar(20)
  djProfileId      String?   @map("dj_profile_id") @db.Uuid
  claimType        String    @map("claim_type") @db.VarChar(10)
  claimedProfileId String?   @map("claimed_profile_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(20)
  rejectionReason  String?   @map("rejection_reason")
  approvedBy       String?   @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("dj_accounts")
}
