{
  "name": "barblink",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "stack:up": "docker compose up -d postgres redis redpanda minio meilisearch",
    "stack:down": "docker compose down",
    "stack:reset": "docker compose down -v",
    "stack:logs": "docker compose logs -f",
    "stack:build": "docker compose build",
    "eas": "./bin/eas",
    "eas:login": "./bin/eas login",
    "eas:whoami": "./bin/eas whoami",
    "eas:build:ios": "./bin/eas build --platform ios --profile preview",
    "eas:build:android": "./bin/eas build --platform android --profile preview"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
